+    def remember_guard_feedback(self, event: dict[str, Any]) -> bool:
+        if self.guard_hook is None:
+            return False
+        payload = {"timestamp": datetime.now().isoformat(timespec="seconds"), **event}
+        payload = self.guard_hook.prepare_feedback_for_original_memory(payload)
+        try:
+            self.guard_hook.persist_feedback(payload, self.config.memory_path)
+        except Exception as exc:  # feedback persistence must not stop Original RecClaw
+            print(f"[EvidenceGuard] feedback write failed open: {type(exc).__name__}: {exc}", file=sys.stderr)
+            return False
+        if payload.get("expose_to_next_iteration") is not True:
+            return True
+        self.memory.append(payload)
+        candidate_id = str(payload.get("candidate_id") or "")
+        if candidate_id:
+            self.history_by_candidate.setdefault(candidate_id, []).append(payload)
+        self.agent_state_summary = self._build_agent_state_summary()
+        self._write_agent_state_summary(self.agent_state_summary)
+        return True
